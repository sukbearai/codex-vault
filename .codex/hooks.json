{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "python3 plugin/hooks/codex/session-start.py",
            "statusMessage": "📚 Codex-Vault loading..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 plugin/hooks/codex/classify-message.py",
            "statusMessage": "🔍 Classifying..."
          }
        ]
      }
    ]
  }
}
