{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .codex-vault/hooks/codex/session-start.py",
            "timeout": 30,
            "statusMessage": "\ud83d\udcda Codex-Vault loading..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .codex-vault/hooks/codex/classify-message.py",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
